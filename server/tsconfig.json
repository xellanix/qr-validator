{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "target": "es2023",
    "moduleResolution": "bundler",
    "types": ["bun"],
    "baseUrl": "..",
    "paths": {
      "@/*": ["frontend/*"],
      "$/*": ["server/*"]
    },
    "plugins": [],
    "lib": ["ES2023"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}