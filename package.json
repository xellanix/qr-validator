{
  "name": "qr-validator-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -c \"green,blue\" -n \"FRONTEND,SERVER\" \"bun run dev:frontend\" \"bun run dev:server\"",
    "dev:server": "bun --hot --define=VERSION:'\"0.0.0\"' run server/index.ts",
    "dev:frontend": "bunx --bun vite",
    "build": "bun run build:frontend && bun run build:server",
    "build:beta": "bun run build:frontend && bun run build:server:beta",
    "build:frontend": "tsc -b && bunx --bun vite build",
    "build:server": "bun run server/build/index.ts",
    "build:server:beta": "bun run build:server --no-release",
    "start": "NODE_ENV=production ./dist/server/projection",
    "lint": "eslint .",
    "pretty": "prettier --write . --end-of-line crlf",
    "preview": "bunx --bun vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@fontsource-variable/figtree": "5.2.10",
    "@hugeicons/core-free-icons": "4.1.1",
    "@hugeicons/react": "1.1.6",
    "@socket.io/bun-engine": "0.1.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fast-csv": "5.0.5",
    "jose": "6.2.3",
    "next-themes": "0.4.6",
    "qr": "0.6.0",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-qr-code": "2.0.18",
    "react-router-dom": "7.14.2",
    "shadcn": "4.4.0",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "zod": "4.4.2",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@eslint/js": "10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/postcss": "4.2.0",
    "@types/babel__core": "7.20.5",
    "@types/bun": "1.3.12",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.24",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "9.2.1",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.10",
    "wait-on": "9.0.3"
  }
}
